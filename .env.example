# Copie este arquivo para .env e preencha somente no servidor/estação local:
#   cp .env.example .env
# O arquivo .env está no .gitignore e não deve ser enviado ao repositório.

# Carregamento do .env
DJANGO_READ_DOT_ENV_FILE=true

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=GERE-UMA-CHAVE-ALEATORIA-FORTE
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_TIME_ZONE=America/Bahia
DJANGO_LOG_LEVEL=INFO
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_SECURE_SSL_REDIRECT=false

# PostgreSQL
POSTGRES_DB=rsc
POSTGRES_USER=rsc
POSTGRES_PASSWORD=DEFINA-UMA-SENHA-LOCAL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Redis/cache
REDIS_URL=redis://cache:6379/1

# E-mail
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Sistema RSC <nao-responda@ufsb.edu.br>

# Arquivos
RSC_MEDIA_ROOT=/app/media
# Em desenvolvimento, o Django faz streaming após autorizar o usuário.
# No compose.prod.yaml, use true para entrega interna pelo Nginx.
RSC_USE_X_ACCEL_REDIRECT=false
RSC_PROTECTED_MEDIA_INTERNAL_URL=/_protected_media/
RSC_MAX_UPLOAD_BYTES=52428800
RSC_ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,webp,tif,tiff,doc,docx,odt,xls,xlsx,ods,csv,txt
RSC_ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,image/tiff,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.oasis.opendocument.text,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.oasis.opendocument.spreadsheet,text/csv,text/plain

# OAuth2 do usuário — Authorization Code
UFSB_AUTH_CLIENT_ID=
UFSB_AUTH_CLIENT_SECRET=
UFSB_AUTH_SCOPE=read
UFSB_AUTHORIZATION_URL=https://sigauth-hom.ufsb.edu.br/authz-server/oauth/authorize
UFSB_AUTH_TOKEN_URL=https://sigauth-hom.ufsb.edu.br/authz-server/oauth/token
UFSB_AUTH_USERINFO_URL=https://api-hom.ufsb.edu.br/public/security/v2/usuarios/me
UFSB_AUTH_USERINFO_API_KEY=
UFSB_AUTH_USER_NAME_ATTRIBUTE=pessoa
UFSB_AUTH_REDIRECT_URI=http://127.0.0.1:8000/autenticacao/callback/
UFSB_AUTH_LOGOUT_URL=https://sigauth-hom.ufsb.edu.br/authz-server/j_spring_cas_security_logout
UFSB_AUTH_LOGOUT_SERVICE_URL=http://127.0.0.1:8000/
UFSB_AUTH_TOKEN_AUTH_METHOD=client_secret_basic
UFSB_AUTH_USE_PKCE=false
UFSB_AUTH_STATE_TTL_SECONDS=600
UFSB_AUTH_TIMEOUT_SECONDS=10
UFSB_AUTH_CONNECT_TIMEOUT_SECONDS=3
UFSB_AUTH_VERIFY_SSL=true
UFSB_AUTH_CA_BUNDLE=

# Credencial técnica das APIs — Client Credentials
UFSB_API_CLIENT_ID=
UFSB_API_CLIENT_SECRET=
UFSB_API_KEY=
UFSB_API_TOKEN_URL=https://sigauth-hom.ufsb.edu.br/authz-server/oauth/token
UFSB_API_SCOPE=
UFSB_API_TOKEN_AUTH_METHOD=client_secret_basic
UFSB_API_TIMEOUT_SECONDS=10
UFSB_API_CONNECT_TIMEOUT_SECONDS=3
UFSB_API_VERIFY_SSL=true
UFSB_API_CA_BUNDLE=
UFSB_API_RATE_LIMIT_ALERT_PERCENT=10
UFSB_API_PAGE_PARAM=page

# Parâmetros de consulta — ajuste se o gateway usar nomes diferentes
UFSB_API_USUARIOS_ID_USUARIO_PARAM=id-usuario
UFSB_API_USUARIOS_LOGIN_PARAM=login
UFSB_API_USUARIOS_ID_INSTITUCIONAL_PARAM=id-institucional
UFSB_API_SERVIDORES_ID_INSTITUCIONAL_PARAM=id-institucional

# Endpoints institucionais
UFSB_API_USUARIOS_URL=https://api-hom.ufsb.edu.br/usuario/v1/usuarios
UFSB_API_SERVIDORES_URL=https://api-hom.ufsb.edu.br/pessoa/v1/servidores
UFSB_API_UNIDADES_URL=https://api-hom.ufsb.edu.br/unidade/v1/unidades
UFSB_API_UNIDADES_LOTACAO_URL=https://api-hom.ufsb.edu.br/pessoa/v1/unidades-lotacao
UFSB_API_UNIDADES_EXERCICIO_URL=https://api-hom.ufsb.edu.br/pessoa/v1/unidades-exercicios
UFSB_API_LOCALIZACOES_SERVIDORES_URL=https://api-hom.ufsb.edu.br/pessoa/v1/localizacoes-servidores
UFSB_API_RESPONSAVEIS_URL=https://api-hom.ufsb.edu.br/pessoa/v1/responsaveis
UFSB_API_ARQUIVOS_URL=https://api-hom.ufsb.edu.br/file/v1/arquivos

# Inicialização do container
RUN_MIGRATIONS=true
RUN_SEED_RSC=true
RUN_COLLECTSTATIC=true
